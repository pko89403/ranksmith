# Provider 선택 — 둘 중 하나만 활성 값으로 두면 됩니다.
# 기본은 lmstudio. azure로 바꾸면 아래 AZURE_* 블록이 사용됩니다.
# LLM과 embedding은 독립적으로 선택 가능합니다.
LLM_PROVIDER=lmstudio          # lmstudio | azure
EMBED_PROVIDER=lmstudio        # lmstudio | azure


# LM Studio
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=qwen/qwen3.6-35b-a3b
EMBED_MODEL=text-embedding-qwen3-embedding-0.6b
LLM_TIMEOUT=1800

# Extract 워크플로우 병렬도. 미설정 시 LLM_PROVIDER 기반 자동 default.
#   lmstudio: 2 (35B 로컬 모델 안정성)
#   azure:    16 (gpt-5.4-nano 부하 측정 기반, 32까지 확장 가능)
EXTRACT_MAX_WORKERS=


# Azure OpenAI 공통
AZURE_OPENAI_ENDPOINT=https://aoai-skiiwoo.openai.azure.com/
AZURE_OPENAI_API_KEY=

# Azure OpenAI Chat
AZURE_OPENAI_LLM_DEPLOYMENT=
AZURE_OPENAI_LLM_API_VERSION=2024-10-21
AZURE_OPENAI_LLM_TIMEOUT=3600
AZURE_OPENAI_LLM_REASONING_EFFORT=none
AZURE_OPENAI_LLM_VERBOSITY=
AZURE_OPENAI_LLM_TEMPERATURE=
AZURE_OPENAI_LLM_TOP_P=

# Azure OpenAI Embedding
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBED_API_VERSION=2024-02-01
AZURE_OPENAI_EMBED_DIMENSIONS=1024
